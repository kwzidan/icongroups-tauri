{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "icongroups-tauri",
  "version": "0.1.4",
  "identifier": "com.karee.icongroups-tauri",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "icongroups-tauri",
        "width": 400,
        "height": 440,
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "permissions": [
        "core:window:allow-set-title",
        "core:window:allow-set-size",
        "core:window:allow-set-focus",
        "core:window:allow-close",
        "core:window:allow-start-dragging",
        "core:event:default"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
